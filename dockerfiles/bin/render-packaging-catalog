#!/bin/bash
# render-packaging-catalog — fill the packaging-line hierarchical catalog template
# from external endpoint knobs just before the ConfigComponent starts.
#
# Usage: render-packaging-catalog <template.json> <output.json> <endpoint> <host:port>
set -euo pipefail

tmpl="$1"; out="$2"; endpoint="$3"; hostport="$4"
host="${hostport%:*}"
port="${hostport##*:}"
mkdir -p "$(dirname "$out")"
sed \
  -e "s|__KEPWARE_ENDPOINT__|${endpoint}|g" \
  -e "s|__MODBUS_HOST__|${host}|g" \
  -e "s|__MODBUS_PORT__|${port}|g" \
  "$tmpl" > "$out"
echo "[render-packaging-catalog] wrote ${out} (endpoint=${endpoint}, modbus=${host}:${port})"
