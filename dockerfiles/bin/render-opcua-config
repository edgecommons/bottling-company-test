#!/bin/bash
# render-opcua-config — fill the packaging-line OPC UA config template from the external-endpoint
# knobs, in-container, just before the adapter starts. Kept as a baked script (rather than inline
# in the supervisord command) so the supervisord command line contains no '%' — supervisord treats
# '%' as its own expansion sigil, and the shell parameter expansion here (${...%...}, etc.) would
# collide with it.
#
# Usage:  render-opcua-config <template.json> <output.json> <endpoint> <user> <pass>
set -euo pipefail

tmpl="$1"; out="$2"; endpoint="$3"; user="$4"; pass="$5"
mkdir -p "$(dirname "$out")"
sed \
  -e "s|__KEPWARE_ENDPOINT__|${endpoint}|g" \
  -e "s|__KEPWARE_USER__|${user}|g" \
  -e "s|__KEPWARE_PASS__|${pass}|g" \
  "$tmpl" > "$out"
echo "[render-opcua-config] wrote ${out} (endpoint=${endpoint})"
