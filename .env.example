# EdgeCommons UNS bottling-company-test — environment knobs.
# Copy to `.env` (docker compose auto-loads it from this directory):  cp .env.example .env
# Every value here matches the built-in ${VAR:-default} fallback in the compose files, so the
# harness also lints/runs without a .env.

# ---- edge-console UI + WS port; open http://localhost:${CONSOLE_PORT} (self-served, no nginx) ----
CONSOLE_PORT=8080

# ---- Host-published broker ports (for MQTTX/debugging; each device's internal port is always 1883) ----
# In the collapsed model each broker lives INSIDE its device container; these publish it to the host.
SITE_BROKER_PORT=18830
FILL_BROKER_PORT=18831
PACK_BROKER_PORT=18832

# ---- Site EMQX dashboard (http://localhost:${SITE_DASHBOARD_PORT}, admin/public) ----
# Remapped OFF 18083 because the standing `edgecommons-emqx` container already publishes 18083 on this host.
SITE_DASHBOARD_PORT=18084

# ============================================================================
# Packaging line (gw-pack-01) EXTERNAL sources — LAN-dependent; the packaging container must be
# able to REACH these addresses. On Docker Desktop, containers reach LAN IPs via the host NAT;
# if a source runs ON this host, use `host.docker.internal` (the packaging service already
# declares host.docker.internal:host-gateway). These are rendered into the config templates at
# process start.
# ============================================================================

# KepWare OPC UA server (opc.tcp endpoint + credentials). Replace the placeholder
# password in .env before starting the packaging-line service.
KEPWARE_ENDPOINT=opc.tcp://192.168.1.180:49320
KEPWARE_USER=testuser
KEPWARE_PASS=CHANGE_ME

# Host Modbus/TCP sim (the standing edgecommons-modbus-sim), as a single host:port. Use
# host.docker.internal:5020 if it runs on THIS machine and the LAN IP isn't routable from containers.
HOST_MODBUS=192.168.1.224:5020
