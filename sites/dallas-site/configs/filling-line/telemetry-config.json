{
  "logging": {
    "level": "INFO",
    "rust_format": "{timestamp} [{level}] {target} - {message}"
  },
  "heartbeat": {
    "enabled": true,
    "intervalSecs": 10,
    "measures": {
      "cpu": true,
      "memory": true
    }
  },
  "metricEmission": {
    "target": "messaging",
    "namespace": "edgecommons"
  },
  "hierarchy": {
    "levels": [
      "site",
      "line",
      "device"
    ]
  },
  "identity": {
    "site": "dallas",
    "line": "filling"
  },
  "streaming": {
    "streams": [
      {
        "name": "archive",
        "sink": {
          "type": "file",
          "format": "parquet",
          "mode": "rows",
          "dir": "/out/archive",
          "partitionBy": "dt={yyyy-MM-dd}/hr={HH}",
          "maxFileBytes": 1048576,
          "maxFiles": 64,
          "rollEverySecs": 20,
          "onFull": "dropOldest",
          "compression": "snappy",
          "rows": {
            "explode": "body.samples",
            "columns": [
              {
                "name": "device",
                "path": "body.device",
                "type": "string"
              },
              {
                "name": "component",
                "path": "body.component",
                "type": "string"
              },
              {
                "name": "signal",
                "path": "body.signalName",
                "type": "string"
              },
              {
                "name": "unit",
                "path": "body.unit",
                "type": "string"
              },
              {
                "name": "rawValue",
                "path": "body.samples[].value",
                "type": "double"
              },
              {
                "name": "engValue",
                "path": "body.samples[].engValue",
                "type": "double"
              },
              {
                "name": "quality",
                "path": "body.samples[].quality",
                "type": "string"
              },
              {
                "name": "sourceTs",
                "path": "body.samples[].sourceTs",
                "type": "string"
              },
              {
                "name": "rate",
                "path": "body.rate",
                "type": "double"
              },
              {
                "name": "alarm",
                "path": "body.alarm",
                "type": "bool"
              }
            ]
          }
        },
        "buffer": {
          "type": "disk",
          "path": "/out/.stream-buffer/archive",
          "segmentBytes": 1048576,
          "maxDiskBytes": 67108864,
          "onFull": "dropOldest"
        },
        "batch": {
          "maxRecords": 200,
          "maxBytes": 1048576,
          "maxLatencyMs": 2000
        },
        "delivery": {
          "pollIntervalMs": 500
        }
      }
    ]
  },
  "component": {
    "global": {
      "defaults": {
        "key": "body.signal.id",
        "scriptEngine": "lua",
        "scriptsDir": "/scripts"
      }
    },
    "instances": [
      {
        "id": "downsample-local",
        "subscribe": [
          "ecv1/+/+/+/data/#"
        ],
        "pipeline": [
          {
            "filter": {
              "quality": "GOOD"
            }
          },
          {
            "sample": {
              "everyMs": 1000,
              "by": "body.signal.id"
            }
          }
        ],
        "target": "local",
        "publish": {
          "topic": "ecv1/{ThingName}/telemetry-processor/main/data/downsampled"
        }
      },
      {
        "id": "archive",
        "subscribe": [
          "ecv1/+/+/+/data/#"
        ],
        "pipeline": [
          {
            "filter": {
              "quality": "GOOD"
            }
          },
          {
            "script": {
              "file": "transform.lua"
            }
          }
        ],
        "target": "stream:archive",
        "publish": {
          "partitionKey": "body.signal.id"
        }
      }
    ],
    "token": "telemetry-processor"
  }
}