{
  "hierarchy": {
    "levels": [
      "site",
      "line",
      "device"
    ]
  },
  "identity": {
    "site": "dallas",
    "line": "filling"
  },
  "tags": {
    "appId": "bottling-plant"
  },
  "logging": {
    "level": "INFO"
  },
  "heartbeat": {
    "enabled": true,
    "intervalSecs": 5,
    "measures": {
      "cpu": true,
      "memory": true
    }
  },
  "metricEmission": {
    "target": "messaging"
  },
  "component": {
    "global": {
      "defaults": {
        "pollIntervalMs": 500,
        "publishMode": "always",
        "batchMs": 0,
        "maxGap": 4
      }
    },
    "instances": [
      {
        "id": "conveyor1",
        "connection": {
          "transport": "tcp",
          "host": "localhost",
          "port": 5020,
          "unitId": 1,
          "timeoutMs": 1000
        },
        "publish": {
          "batchMs": 0
        },
        "write": {
          "enabled": false
        },
        "pollGroups": [
          {
            "id": "main",
            "pollIntervalMs": 500,
            "publishMode": "always",
            "signals": [
              {
                "name": "BottleCount",
                "table": "holding",
                "address": 0,
                "type": "uint16"
              },
              {
                "name": "ProductTemp",
                "table": "holding",
                "address": 1,
                "type": "float32"
              },
              {
                "name": "FillLevel",
                "table": "holding",
                "address": 40,
                "type": "uint16",
                "scale": 0.1
              }
            ]
          }
        ]
      }
    ],
    "token": "modbus-adapter"
  }
}